      },
      {
        "action": "assertVisible",
        "target": "getByRole('heading', { name: /^Settings$/ })"
      },
      {
        "action": "check",
        "target": "getByLabel(/Enable Testing Mode/i)"
      },
      {
        "action": "assertVisible",
        "target": "getByLabel(/Enable Testing Mode/i)"
      },
      {
        "action": "click",
        "target": "getByRole('link', { name: /^Dashboard$/ })",
        "description": "Dashboard navigation link in the sidebar"
      },
      {
        "action": "waitForURL",
        "target": "https://retail-website-two.vercel.app/app/dashboard"
      },
      {
        "action": "assertVisible",
        "target": "getByRole('heading', { name: /^Dashboard$/ })"
      },
      {
        "action": "click",
        "target": "getByRole('link', { name: /^Products$/ })",
        "description": "Products navigation link in the sidebar while testing mode is enabled"
      },
      {
        "action": "waitForURL",
        "target": "https://retail-website-two.vercel.app/app/products"
      },
      {
        "action": "assertVisible",
        "target": "getByRole('heading', { name: /^Products$/ })"
      },
      {
        "action": "assertCountAtLeast",
        "target": "locator('[id^=\"p_\"]')",
        "value": 1
      },
      {
        "action": "assertVisible",
        "target": "locator('input.rw-input[class*=\"q-\"]')"
      },
      {
        "action": "click",
        "target": "locator('button:enabled').filter({ hasText: /^Add to cart$/ }).first()",
        "description": "First enabled Add to cart button in the products grid while testing mode is enabled"
      },
      {
        "action": "assertText",
        "target": "getByRole('button', { name: /^Cart \\d+$/ })",
        "value": "Cart 1"
      },
      {
        "action": "click",
        "target": "getByRole('link', { name: /^Cart$/ })",
        "description": "Cart navigation link in the sidebar while testing mode is enabled"
      },
      {
        "action": "waitForURL",
        "target": "https://retail-website-two.vercel.app/app/cart"
      },
      {
        "action": "assertVisible",
        "target": "getByRole('button', { name: /^Remove$/ })"
      },
      {
        "action": "click",
        "target": "getByRole('button', { name: /^Checkout$/ })",
        "description": "Checkout button on the cart page while testing mode is enabled"
      },
      {
        "action": "waitForURL",
        "target": "https://retail-website-two.vercel.app/app/checkout"
      },
      {
        "action": "assertVisible",
        "target": "getByRole('heading', { name: /^Checkout$/ })"
      },
      {
        "action": "fill",
        "target": "getByLabel('Full name')",
        "value": "Testing Mode Customer"
      },
      {
        "action": "fill",
        "target": "getByLabel('Address')",
        "value": "123 Demo Street"
      },
      {
        "action": "fill",
        "target": "getByLabel('City')",
        "value": "Kolkata"
      },
      {
        "action": "fill",
        "target": "getByLabel('Postal')",
