[
  {
    "name": "customer can log in, add an item to cart, complete checkout, and return to dashboard",
    "testId": "retail-customer-healing-001",
    "timeoutMs": 180000,
    "steps": [
      {
        "action": "goto",
        "target": "https://retail-website-two.vercel.app/login"
      },
      {
        "action": "assertVisible",
        "target": "getByText('Sign in to your workspace')"
      },
      {
        "action": "fill",
        "target": "getByLabel('Email')",
        "value": "test@demo.com",
        "description": "Email address input field on the retail login page"
      },
      {
        "action": "fill",
        "target": "getByLabel('Password')",
        "value": "password123",
        "description": "Password input field on the retail login page"
      },
      {
        "action": "click",
        "target": "getByRole('button', { name: /^Sign in$/i })",
        "description": "Sign in button on the login form"
      },
      {
        "action": "waitForURL",
        "target": "https://retail-website-two.vercel.app/app/dashboard"
      },
      {
        "action": "assertVisible",
        "target": "getByText('test@demo.com · customer')"
      },
      {
        "action": "assertVisible",
        "target": "getByRole('heading', { name: /^Dashboard$/ })"
      },
      {
        "action": "assertVisible",
        "target": "getByText('Order #5033 confirmed')"
      },
      {
        "action": "click",
        "target": "getByRole('link', { name: /^Products$/ })",
        "description": "Products navigation link in the sidebar"
      },
      {
        "action": "waitForURL",
        "target": "https://retail-website-two.vercel.app/app/products"
      },
      {
        "action": "assertVisible",
        "target": "getByRole('heading', { name: /^Products$/ })"
      },
      {
        "action": "assertVisible",
        "target": "getByText('Classic Backpack')"
      },
      {
        "action": "click",
        "target": "locator('button:enabled').filter({ hasText: /^Add to cart$/ }).first()",
        "description": "First enabled Add to cart button in the products grid"
      },
      {
        "action": "assertText",
        "target": "getByRole('button', { name: /^Cart \\d+$/ })",
        "value": "Cart 1"
      },
      {
        "action": "click",
        "target": "getByRole('link', { name: /^Cart$/ })",
        "description": "Cart navigation link in the sidebar"
      },
      {
        "action": "waitForURL",
        "target": "https://retail-website-two.vercel.app/app/cart"
      },
      {
        "action": "assertVisible",
        "target": "getByRole('heading', { name: /^Your cart$/ })"
      },
      {
        "action": "assertVisible",
        "target": "getByRole('button', { name: /^Remove$/ })"
      },
      {
        "action": "click",
        "target": "getByRole('button', { name: /^Checkout$/ })",
        "description": "Checkout button on the cart page"
      },
      {
        "action": "waitForURL",
        "target": "https://retail-website-two.vercel.app/app/checkout"
      },
      {
        "action": "assertVisible",
        "target": "getByRole('heading', { name: /^Checkout$/ })"
      },
      {
        "action": "fill",
        "target": "getByLabel('Full name')",
        "value": "Test Customer"
      },
      {
        "action": "fill",
        "target": "getByLabel('Address')",
        "value": "123 Demo Street"
      },
      {
        "action": "fill",
        "target": "getByLabel('City')",
        "value": "Kolkata"
      },
      {
        "action": "fill",
        "target": "getByLabel('Postal')",
        "value": "700001"
      },
      {
        "action": "assertVisible",
        "target": "locator('button').filter({ hasText: /^Pay (US)?\\$/ }).first()"
      },
      {
        "action": "click",
        "target": "locator('button').filter({ hasText: /^Pay (US)?\\$/ }).first()",
        "description": "Pay button on the checkout page"
      },
      {
        "action": "assertVisible",
        "target": "getByText(/Order .* confirmed\\./)"
      },
      {
        "action": "assertVisible",
        "target": "getByRole('button', { name: /^Cart 0$/ })"
      },
      {
        "action": "click",
        "target": "getByRole('link', { name: /^Dashboard$/ })",
        "description": "Dashboard navigation link in the sidebar"
      },
      {
        "action": "waitForURL",
        "target": "https://retail-website-two.vercel.app/app/dashboard"
      },
      {
        "action": "assertVisible",
        "target": "getByRole('heading', { name: /^Dashboard$/ })"
      },
      {
        "action": "assertVisible",
        "target": "getByText('test@demo.com · customer')"
      }
    ]
  },
