  {
    "name": "customer can enable testing mode in settings and complete the storefront flow",
    "testId": "retail-testing-mode-healing-001",
    "timeoutMs": 180000,
    "steps": [
      {
        "action": "goto",
        "target": "https://retail-website-two.vercel.app/login"
      },
      {
        "action": "assertVisible",
        "target": "getByText('Sign in to your workspace')"
      },
      {
        "action": "fill",
        "target": "getByLabel('Email')",
