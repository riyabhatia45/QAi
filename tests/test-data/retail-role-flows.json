        "description": "Email address input field on the retail login page"
      },
      {
        "action": "fill",
        "target": "getByLabel('Password')",
        "value": "password123",
        "description": "Password input field on the retail login page"
      },
      {
        "action": "click",
        "target": "getByRole('button', { name: /^Sign in$/i })",
