[
  {
    "name": "customer can log in and land on the dashboard",
    "testId": "retail-customer-smoke-001",
    "timeoutMs": 120000,
    "steps": [
      { "action": "goto", "target": "https://retail-website-two.vercel.app/login" },
      { "action": "assertVisible", "target": "getByText('Sign in to your workspace')" },
      { "action": "fill", "target": "getByLabel('Email')", "value": "test@demo.com", "description": "Customer email input" },
      { "action": "fill", "target": "getByLabel('Password')", "value": "password123", "description": "Customer password input" },
      { "action": "click", "target": "getByRole('button', { name: /^Sign in$/i })", "description": "Sign in button" },
      { "action": "waitForURL", "target": "https://retail-website-two.vercel.app/app/dashboard" },
      { "action": "assertVisible", "target": "getByText('test@demo.com · customer')" },
      { "action": "assertVisible", "target": "getByRole('heading', { name: /^Dashboard$/ })" }
    ]
  },
