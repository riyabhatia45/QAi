# ─── AI Provider ────────────────────────────────────────────────────────
# Options: openai | google | groq
AI_PROVIDER=google

# ─── Google Gemini ──────────────────────────────────────────────────────
# Get your FREE key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here
AI_SELECTOR_MODEL=gemini-2.0-flash
AI_FLOW_MODEL=gemini-2.0-flash

# ─── OpenAI ─────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_SELECTOR_MODEL=gpt-4o-mini
# OPENAI_FLOW_MODEL=gpt-4o

# ─── Groq ───────────────────────────────────────────────────────────────
# Get your FREE key at: https://console.groq.com/keys
GROQ_API_KEY=
# AI_SELECTOR_MODEL=llama-3.3-70b-versatile
# AI_FLOW_MODEL=llama-3.3-70b-versatile

# ─── Execution Mode ────────────────────────────────────────────────────
# strict   – no medium-confidence healing (CI / main branch)
# adaptive – allows medium-confidence healing (regression / local)
HEAL_MODE=adaptive

# ─── Optional Tuning ───────────────────────────────────────────────────
# MAX_DETERMINISTIC_RETRIES=2
# ACTION_TIMEOUT_MS=10000
# MAX_DOM_EXCERPT=4000
# CAPTURE_SCREENSHOTS=true
# CAPTURE_TRACES=true
